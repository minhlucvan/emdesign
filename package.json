{
  "name": "emdesign",
  "version": "0.0.0",
  "private": true,
  "description": "Design Engineering for the agent era — a Studio backend that drives Storybook as its front end.",
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*",
    "tests"
  ],
  "scripts": {
    "backend": "npm run dev -w @emdesign/cli",
    "studio": "npm run storybook -w @emdesign/workspace-react",
    "dev": "npm run backend & npm run studio",
    "build": "bash scripts/build.sh",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke",
    "test:visual": "npm run test:visual -w @emdesign/workspace-react"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "@types/pixelmatch": "^5.2.6",
    "vitest": "^2.1.9"
  }
}
