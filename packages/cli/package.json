{
  "name": "@emdesign/cli",
  "version": "0.1.0-alpha.0",
  "type": "module",
  "description": "emdesign CLI — the client the AI (and workspace commands/gates) invoke. Proxies to a running server over HTTP, or embeds the @emdesign/backend engine for one-shot ops. Also provides init/attach.",
  "bin": {
    "emdesign": "dist/cli.js",
    "emdesign-backend": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "scripts": {
    "dev": "tsx src/cli.ts serve",
    "serve": "tsx src/cli.ts serve",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js serve",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@emdesign/backend": "^0.1.0-alpha.0",
    "@emdesign/graph": "^0.1.0-alpha.0",
    "@emdesign/vision-critic": "^0.1.0-alpha.0",
    "@emdesign/visual-diff": "^0.1.0-alpha.0",
    "@emdesign/plugin-react-doctor": "^0.1.0-alpha.0",
    "@emdesign/workspace": "^0.1.0-alpha.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  }
}
